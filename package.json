{
  "name": "yy-workflow-aigc",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @yy-workflow-aigc/db",
    "db:studio": "turbo run db:studio -F @yy-workflow-aigc/db",
    "db:generate": "turbo run db:generate -F @yy-workflow-aigc/db",
    "db:migrate": "turbo run db:migrate -F @yy-workflow-aigc/db",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@yy-workflow-aigc/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "catalog:",
    "@yy-workflow-aigc/config": "workspace:*",
    "turbo": "^2.10.2",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "packageManager": "pnpm@10.33.2"
}
